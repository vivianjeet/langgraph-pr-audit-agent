# LLM Provider API Keys
# GEMINI_API_KEY is required. KEY2/KEY3/KEY4 are optional extra keys the resilience layer rotates
# to on quota exhaustion; each is a separate billing project. Leave any you don't have unset.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY2=your_gemini_api_key_here
GEMINI_API_KEY3=your_gemini_api_key_here
GEMINI_API_KEY4=your_gemini_api_key_here

# For CI: the tracing values below are LOCAL config. To trace the GitHub Actions gate, put the same
# API keys in repo Secrets and the rest in repo Variables - see the README's CI section for the split.

#LangSmith Tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=langgraph-pr-audit-agent
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"

#PGVector Docker
POSTGRES_USER=your_docker_postgres_username_here
POSTGRES_PASSWORD=your_docker_postgres_password_here
POSTGRES_DB=your_docker_postgres_database_name_here

#Postgres
POSTGRES_PORT=your_application_postgres_port_here
DATABASE_URL=your_application_database_url_here

#Langfuse
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_HOST="https://cloud.langfuse.com"
